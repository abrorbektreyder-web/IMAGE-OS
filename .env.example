# AI ImageOS - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/imageos_db"

# ==========================================
# REDIS
# ==========================================
REDIS_URL="redis://localhost:6379"

# ==========================================
# AUTH (Better Auth)
# ==========================================
# Vercel (production) uchun MAJBURIY env'lar — bularsiz /api/auth/* 500 qaytaradi:
#   DATABASE_URL, BETTER_AUTH_SECRET, BETTER_AUTH_URL (=https://image-os-web.vercel.app),
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
# Google Console'da redirect URI: <APP_URL>/api/auth/callback/google
BETTER_AUTH_SECRET="your-secret-key-here"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==========================================
# STORAGE (Cloudflare R2 / S3)
# ==========================================
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="imageos-assets"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# ==========================================
# NEXT.JS FRONTEND
# ==========================================
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# BACKEND API
# ==========================================
PORT=4000
NODE_ENV="development"

# ==========================================
# AI PROVIDERS (Phase 2 - V2)
# ==========================================
# REPLICATE_API_TOKEN="your-replicate-token"
# FAL_AI_API_KEY="your-fal-ai-key"
# IMAGINE_API_KEY="your-imagine-key"
